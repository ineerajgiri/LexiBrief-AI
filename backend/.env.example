PORT=5001
GEMINI_API_KEY=your_google_gemini_api_key_here
# Use direct shard hosts (not mongodb+srv) if local DNS blocks SRV lookups.
# URL-encode special characters in password (@ → %40).
MONGO_URI=mongodb://username:password@shard-00-00.example.mongodb.net:27017,shard-00-01.example.mongodb.net:27017,shard-00-02.example.mongodb.net:27017/legal_saas_db?ssl=true&replicaSet=atlas-example-shard-0&authSource=admin&retryWrites=true&w=majority
